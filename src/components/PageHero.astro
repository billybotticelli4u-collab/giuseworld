---
interface Props { eyebrow: string; title: string; img: string; accent?: string; sub?: string; }
const { eyebrow, title, img, accent = '', sub = '' } = Astro.props as Props;
---
<section class="phero">
  <div class="phero-bg" aria-hidden="true">
    <img class="kenburns" src={img} alt="" />
    <div class="phero-veil"></div>
  </div>
  <div class="phero-inner wrap wrap--wide">
    <p class={`eyebrow ${accent}`}>{eyebrow}</p>
    <h1 class="phero-title">{title}</h1>
    {sub && <p class="phero-sub">{sub}</p>}
  </div>
</section>
<style>
  .phero { position: relative; overflow: hidden; min-height: clamp(20rem, 46vh, 30rem); display: flex; align-items: flex-end; margin-bottom: 0.5rem; }
  .phero-bg { position: absolute; inset: 0; z-index: 0; }
  .phero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .kenburns { animation: phkb 26s ease-in-out infinite alternate; transform-origin: 55% 40%; }
  @keyframes phkb { from { transform: scale(1.03); } to { transform: scale(1.12); } }
  .phero-veil { position: absolute; inset: 0; background:
    linear-gradient(180deg, rgba(13,9,8,0.55) 0%, rgba(13,9,8,0.25) 32%, rgba(13,9,8,0.82) 82%, var(--ink) 100%),
    radial-gradient(120% 80% at 50% 20%, rgba(13,9,8,0) 40%, rgba(13,9,8,0.5) 100%); }
  .phero-inner { position: relative; z-index: 2; padding-top: 7rem; padding-bottom: 2.2rem; }
  .phero-title { font-size: clamp(2.4rem, 7vw, 5rem); font-weight: 600; margin: 0.1em 0 0; text-shadow: 0 2px 30px rgba(0,0,0,0.45); }
  .phero-sub { color: var(--ivory-cream); font-family: var(--font-display); font-style: italic; font-size: clamp(1.05rem, 2.4vw, 1.5rem); margin: 0.6rem 0 0; max-width: 40ch; }
  @media (prefers-reduced-motion: reduce) { .kenburns { animation: none; } }
</style>
