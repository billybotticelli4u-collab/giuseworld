---
import site from '../data/site.json';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap wrap--wide inner">
    <span>{site.nomeProgetto} — {year}</span>
    <nav>
      <a href="/unisciti">Unisciti</a>
      <a href={`mailto:${site.emailProgetto}`}>{site.emailProgetto}</a>
      <a href="/privacy">Privacy</a>
    </nav>
  </div>
</footer>
<style>
  .site-footer { margin-top: 4rem; background: var(--ink-2); color: var(--ivory-cream); border-top: 1px solid var(--line); }
  .inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 0.75rem; padding-block: 1.6rem; font-size: 0.85rem; }
  .site-footer a { color: var(--ivory-cream); text-decoration-color: var(--camel); margin-left: 1.1rem; }
  .site-footer nav { display: flex; flex-wrap: wrap; }
  .site-footer a:first-child { margin-left: 0; }
  @media (max-width: 520px) { .site-footer a { margin-left: 0; margin-right: 1.1rem; } }
</style>
