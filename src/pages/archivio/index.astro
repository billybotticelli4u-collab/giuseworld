---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getTracce, byDateDesc, formatDate } from '../../lib/content';
const tracce = byDateDesc(await getTracce());
---
<Base title="Archivio Musicale" description="I capitoli del progetto.">
  <PageHero eyebrow="Archivio Musicale" title="Cosa hai creato?" img="/media/heroes/archivio.jpg" />
  <div class="wrap page">
    <p>I capitoli del progetto, dal più recente. Ogni traccia è una pagina a sé.</p>
    {tracce.length === 0 ? (
      <p class="meta">Nessuna traccia pubblicata.</p>
    ) : (
      <ul class="index-list">
        {tracce.map((t) => (
          <li>
            <a href={`/archivio/${t.id}`}>
              <span class="t">{t.data.titolo}</span>
              <span class="d">{formatDate(new Date(t.data.data))}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>
